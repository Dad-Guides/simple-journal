# Copy to docker-compose.override.yml to use an external Postgres.
# Also update DATABASE_URL in docker-compose.yml to point at your external host.

services:
  db:
    profiles:
      - disabled   # prevents db from starting; never matches a --profile flag

  journal-web:
    depends_on: {}   # removes healthcheck dependency on bundled db
    # Uncomment to join an external Docker network:
    # networks:
    #   - your-network-name

# networks:
#   your-network-name:
#     external: true
