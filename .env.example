# ── LOCAL DEVELOPMENT ONLY ────────────────────────────────────────────────────
# This file is a reference for running the app outside Docker (npm run dev).
# For Docker deployments, set all variables directly in docker-compose.yml.
# Copy to .env and fill in values before running `npm run dev`.

# ── Database ──────────────────────────────────────────────────────────────────
# Option A (default): bundled Postgres — set these three vars.
POSTGRES_DB=journal
POSTGRES_USER=journal
POSTGRES_PASSWORD=changeme          # required; no default

# Option B: external Postgres — set DATABASE_URL directly.
# When set, this overrides the auto-constructed URL above.
# DATABASE_URL=postgres://user:pass@your-host:5432/dbname

# ── AI Provider (any OpenAI-compatible endpoint) ──────────────────────────────
# Examples:
#   Ollama:  http://localhost:11434/v1
#   Gemini:  https://generativelanguage.googleapis.com/v1beta/openai
#   OpenAI:  https://api.openai.com/v1
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=mistral:latest
# AI_API_KEY=          # required for cloud providers; omit for local Ollama

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# In Docker, JWT_SECRET is auto-generated on first boot and persisted to a volume.
JWT_SECRET=replace-with-a-long-random-secret

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3003
NEXT_PUBLIC_APP_URL=http://localhost:3003
SESSION_COOKIE_SECURE=false
